{% extends 'base.html.twig' %}

{% block title %}Home - Palmon Survival Wiki{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --panel-bg: #ffffff;
            --panel-shadow: rgba(0, 0, 0, 0.1);
        }

        .hero-section {
            text-align: center;
            padding: 2.5rem 1rem;
            /* Using a slightly darker gradient for better text pop */
            background: linear-gradient(135deg, #2c3e50 0%, #1a252f 100%); 
            color: #ffffff; /* Explicitly set text to white */
            border-radius: 12px;
            margin-bottom: 2rem;
        }

        .hero-section h1 {
            color: #ffffff; /* Force white for the title */
            text-shadow: 0 2px 4px rgba(0,0,0,0.3); /* Adds depth and readability */
            margin-bottom: 0.5rem;
        }

        .hero-section p {
            color: #bdc3c7; /* A light silver/grey for the subtitle */
            font-weight: 500;
        }

        .quest-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .quest-card {
            background: var(--panel-bg);
            border: 2px solid #e0e0e0;
            border-radius: 15px;
            padding: 1.5rem;
            text-decoration: none;
            color: inherit;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        .quest-card:hover {
            transform: translateY(-5px);
            border-color: var(--accent);
            box-shadow: 0 10px 20px var(--panel-shadow);
        }

        .quest-card h2 {
            margin: 0.5rem 0;
            font-size: 1.4rem;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .quest-card p {
            font-size: 0.95rem;
            color: #666;
            margin-bottom: 1rem;
        }

        .quest-tag {
            font-size: 0.75rem;
            font-weight: bold;
            text-transform: uppercase;
            color: var(--accent);
            letter-spacing: 1px;
        }

        .btn-enter {
            margin-top: auto;
            background: #f0f0f0;
            padding: 0.5rem;
            border-radius: 8px;
            text-align: center;
            font-weight: bold;
            font-size: 0.9rem;
            transition: background 0.2s;
        }

        .quest-card:hover .btn-enter {
            background: var(--accent);
            color: white;
        }

        /* Status Bar Simulation */
        .status-bar {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 1.5rem;
            flex-wrap: wrap; /* Good for mobile/Fold 7 screens */
        }

        .status-item {
            background: rgba(255, 255, 255, 0.15); /* Slightly more opaque */
            color: #ffffff;
            padding: 6px 16px;
            border-radius: 20px;
            font-family: 'Courier New', Courier, monospace;
            font-size: 0.85rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(4px); /* Modern "Glassmorphism" effect */
        }
    </style>
{% endblock %}

{% block body %}
<main>
    <section class="hero-section">
        <h1>🎮 Palmon Survival Command Center</h1>
        <p>Your database for dominating the frontier.</p>
        
        <div class="status-bar">
            <span class="status-item">📡 SERVER: ONLINE</span>
            <span class="status-item">🧬 VERSION: 1.0.0</span>
            <span class="status-item">⚔️ ROLE: SURVIVOR</span>
        </div>
    </section>

    <div class="quest-grid">
        <a href="{{ path('app_palmon_power') }}" class="quest-card">
            <span class="quest-tag">Combat Training</span>
            <h2>🐾 Palmon Power</h2>
            <p>Learn how to pick your core squad, manage elements, and maximize your Palmon's growth potential.</p>
            <div class="btn-enter">OPEN GUIDE</div>
        </a>

        <a href="{{ path('app_camp_power') }}" class="quest-card">
            <span class="quest-tag">Infrastructure</span>
            <h2>🏰 Camp Progression</h2>
            <p>A deep dive into the 11 categories of power. Understand where your strength actually comes from.</p>
            <div class="btn-enter">VIEW ANALYSIS</div>
        </a>

        <div class="quest-card" style="opacity: 0.7; cursor: not-allowed; border-style: dashed;">
            <span class="quest-tag" style="color: #999;">Locked</span>
            <h2 style="color: #999;">🥚 Hatching & Altar</h2>
            <p>Coming Soon: Mastering the RNG of the Altar and optimizing your hatch rates.</p>
            <div class="btn-enter">LOCKED</div>
        </div>
    </div>

    <div class="power-profile" style="margin-top: 3rem; text-align: center;">
        <h3>💡 Survivor Tip</h3>
        <p>"A balanced base supports a specialized army. Don't forget your Tech Power research!"</p>
    </div>
</main>
{% endblock %}