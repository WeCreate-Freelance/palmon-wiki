{% extends 'base.html.twig' %}

{% block title %}Camp Upgrade Requirements - Palmon Survival Wiki{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .blueprint-container {
            background: #fff;
            padding: 1.5rem;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            margin-top: 1rem;
        }

        .table-responsive {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            border-radius: 8px;
        }

        .upgrade-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
            min-width: 900px;
        }

        .upgrade-table thead th {
            background-color: var(--primary);
            color: white;
            padding: 14px;
            text-align: left;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .upgrade-table tbody tr {
            border-bottom: 1px solid #eee;
            transition: background 0.2s;
        }

        .upgrade-table tbody tr:hover {
            background-color: #f1f7ff;
        }

        .upgrade-table td {
            padding: 12px;
            vertical-align: middle;
        }

        .lvl-col {
            font-weight: bold;
            color: var(--accent);
            background: #fdfdfd;
            text-align: center !important;
            width: 60px;
            border-right: 2px solid #eee;
        }

        .req-tag {
            display: inline-block;
            background: #e9ecef;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            color: #495057;
            border: 1px solid #dee2e6;
            margin: 2px 0;
            white-space: nowrap;
        }

        .res-val { font-weight: 600; font-family: 'Segoe UI', Roboto, sans-serif; }
        .gold { color: #d4af37; }
        .lumber { color: #8b4513; }
        .steel { color: #5d6d7e; }
        .time { color: #2ecc71; }
        .tbu { color: #bbb; font-style: italic; font-size: 0.8rem; }

        .legend {
            display: flex;
            gap: 20px;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            padding: 12px;
            background: #f8f9fa;
            border-radius: 8px;
            border-left: 4px solid var(--accent);
        }

        .legend span { font-weight: bold; font-size: 0.9rem; }
    </style>
{% endblock %}

{% block body %}
<main>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            {% for breadcrumb in breadcrumbs %}
                {% if breadcrumb.url %}
                    <li class="breadcrumb-item"><a href="{{ breadcrumb.url }}">{{ breadcrumb.name }}</a></li>
                {% else %}
                    <li class="breadcrumb-item active" aria-current="page">{{ breadcrumb.name }}</li>
                {% endif %}
            {% endfor %}
        </ol>
    </nav>

    <div class="category-header" style="display: flex; align-items: center; gap: 15px; margin-bottom: 1rem;">
